rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSuper() {
      // Rely on trusted custom claims only.
      return signedIn() && request.auth.token.role == "super";
    }

    function isOwnOffice(officeId) {
      return signedIn() && (
        request.auth.uid == officeId ||
        (
          exists(/databases/$(database)/documents/offices/$(officeId)) &&
          get(/databases/$(database)/documents/offices/$(officeId)).data.uid == request.auth.uid
        )
      );
    }

    function noLegacyPasswordFieldWrite() {
      return !("password" in request.resource.data);
    }

    function noCredentialFieldWrite() {
      return !(
        "credentialHash" in request.resource.data ||
        "credentialSalt" in request.resource.data ||
        "credentialAlgo" in request.resource.data ||
        "credentialIterations" in request.resource.data ||
        "credentialKeyLength" in request.resource.data
      );
    }

    function ownOfficeAllowedUpdate(officeId) {
      return isOwnOffice(officeId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "passwordChanged",
          "passwordChangedAt",
          "lastLoginAt",
          "updatedAt"
        ]);
    }

    // Offices directory for admin users.
    match /offices/{officeId} {
      // Kept broad for current dashboard flows. Tighten to isSuper() || isOwnOffice(officeId)
      // only after client queries are office-scoped.
      allow read: if signedIn();

      // Only super admins can create office accounts.
      allow create: if isSuper() && noLegacyPasswordFieldWrite() && noCredentialFieldWrite();

      // Super admins can update any office metadata except credential internals from client SDK.
      // Office users can only update a minimal safe set of self fields.
      allow update: if (
        isSuper() &&
        noLegacyPasswordFieldWrite() &&
        noCredentialFieldWrite()
      ) || ownOfficeAllowedUpdate(officeId);

      // Protect super admin account from accidental deletion.
      allow delete: if isSuper() && resource.data.role != "super";
    }

    // Visitor logs.
    match /visits/{visitId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isSuper();
    }

    // Feedback entries.
    match /feedbacks/{feedbackId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isSuper();
    }

    // Append-only audit logs.
    match /activityLogs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // Sensitive reset tokens must be handled by backend/Admin SDK only.
    match /passwordResetTokens/{tokenId} {
      allow read, write: if false;
    }

    // Must only be handled by backend/Admin SDK.
    match /passwordResetRequests/{requestId} {
      allow read, write: if false;
    }

    // Admin notifications are server-managed.
    match /adminNotifications/{notificationId} {
      allow read: if isSuper();
      allow write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
